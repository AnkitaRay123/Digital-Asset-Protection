# ================================================
# Digital Asset Protection — Environment Variables
# ================================================

# ──────────────────────────────────────────────
# FRONTEND (Vite build-time — set in hosting dashboard)
# ──────────────────────────────────────────────

# URL of the deployed backend (Flask) service.
# Example: https://digital-asset-protection-backend.onrender.com
VITE_API_URL=http://localhost:5000

# ──────────────────────────────────────────────
# BACKEND (Python / Flask — set in hosting dashboard)
# ──────────────────────────────────────────────

# MongoDB Atlas connection string.
# Example: mongodb+srv://user:password@cluster.mongodb.net/digital_asset_protection
MONGODB_URI=mongodb://localhost:27017/

# URL of the backend itself (used by the crawler to call /check-similarity internally).
# Example: https://digital-asset-protection-backend.onrender.com
API_BASE_URL=http://localhost:5000

# Flask environment (development / production)
FLASK_ENV=development

# ──────────────────────────────────────────────
# OPTIONAL — Email alerts (leave blank to disable)
# ──────────────────────────────────────────────
SMTP_EMAIL=your@email.com
SMTP_PASSWORD=your_app_password

# ──────────────────────────────────────────────
# OPTIONAL — Webhook alerts
# ──────────────────────────────────────────────
WEBHOOK_URL=https://hooks.example.com/your-webhook
